{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Academy Module Schema",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "id": { "type": "number" },
      "title": { "type": "string" },
      "description": { "type": "string" },
      "objective": { "type": "string" },
      "task": { "type": "string" },
      "lessons": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "id": { "type": "string" },
            "title": { "type": "string" },
            "keywords": { "type": "object", "additionalProperties": { "type": "string" } },
            "sections": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": { "type": "string" },
                  "title": { "type": "string" },
                  "contentChunks": {
                    "type": "array",
                    "items": {
                      "oneOf": [
                        {
                          "type": "object",
                          "properties": {
                            "type": { "enum": ["text", "video"] },
                            "content": { "type": "string" },
                            "duration": { "type": "number" }
                          },
                          "required": ["type", "content"]
                        },
                        {
                          "type": "object",
                          "properties": {
                            "type": { "const": "interactive" },
                            "gamification": {
                              "type": "object",
                              "properties": {
                                "type": { "enum": ["quickCheck", "madLib", "multipleChoice"] },
                                "data": { "type": "object" }
                              },
                              "required": ["type", "data"]
                            }
                          },
                          "required": ["type", "gamification"]
                        }
                      ]
                    }
                  },
                  "inlineGamification": {
                    "type": "object",
                    "properties": {
                      "type": { "enum": ["quickCheck", "madLib", "multipleChoice"] },
                      "data": { "type": "object" }
                    },
                    "required": ["type", "data"]
                  }
                },
                "required": ["id", "contentChunks"]
              }
            }
          },
          "required": ["id", "title", "sections"]
        }
      },
      "gamification": {
        "type": "object",
        "properties": {
          "flashcards": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "question": { "type": "string" },
                "answer": { "type": "string" }
              },
              "required": ["question", "answer"]
            }
          }
        },
        "required": ["flashcards"]
      }
    },
    "required": ["id", "title", "description", "objective", "task", "lessons", "gamification"]
  }
}
